# Required: Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# REQUIRED (For Security): Your Telegram chat ID (get from @userinfobot)
# When set, ONLY this user can access the bot - no /auth allowed
OWNER_CHAT_ID=your_telegram_chat_id_here

# Optional: Bot password (NOT USED if owner-only mode)
# Only set if you want to allow other users to authenticate
BOT_PASSWORD=

# Optional: Google Workspace (Calendar & Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: GitHub Integration
# 1. Create Personal Access Token: https://github.com/settings/tokens
# 2. Select scopes: repo, read:user, workflow
# 3. Paste token below
GITHUB_TOKEN=your_github_pat_here